{
  "name": "synaipse",
  "version": "0.1.0",
  "private": true,
  "description": "Persistent knowledge base & long-term memory for Claude Code",
  "license": "ISC",
  "author": "Stefan Werfling",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "watch": "tsc --build --watch",
    "lint": "eslint packages",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "npm --workspace @synaipse/mcp-server run start",
    "mcp:http": "npm --workspace @synaipse/mcp-server run start:http",
    "web": "npm --workspace @synaipse/web run dev",
    "vault:init": "node scripts/init-vault.mjs",
    "crawl": "npm --workspace @synaipse/crawler run start --silent --",
    "crawl:github-stars": "npm --workspace @synaipse/crawler run start --silent -- github-stars",
    "crawl:devto": "npm --workspace @synaipse/crawler run start --silent -- devto",
    "compile": "npm --workspace @synaipse/crawler run start --silent -- compile",
    "relink": "npm --workspace @synaipse/crawler run start --silent -- relink",
    "docker:up:voyage": "docker-compose --profile voyage up -d",
    "docker:up:ollama": "docker-compose --profile ollama up -d",
    "docker:down": "docker-compose --profile voyage --profile ollama down"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}