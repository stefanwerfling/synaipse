SYNAIPSE_VAULT_PATH=./vault
# Defaults to <SYNAIPSE_VAULT_PATH>/.synaipse-index.json (hidden sidecar
# inside the vault). Override only if you want the cache somewhere else.
# SYNAIPSE_INDEX_CACHE=./data/synaipse-index.json

# --- Runtime mode ---
# local  = filesystem vault, sidecar index, ngit synchronously in the
#          write path. Default. No extra services required.
# server = MariaDB hot-tier for notes + chats (see ADR
#          Memory/synaipse/decisions/2026-06-23-server-mode-architecture.md).
#          Vault path is still set but not used for note IO — keep it
#          pointing at /tmp or any writable directory while only the DB
#          adapters carry traffic. ngit history is silent (NoopHistory)
#          until the Phase-3 commit-worker lands.
SYNAIPSE_MODE=local

# --- MariaDB (required when SYNAIPSE_MODE=server) ---
# Spin up the bundled container with `npm run docker:up:server`. The
# default port is 3307 (not 3306) because most dev hosts already have a
# MariaDB/MySQL on 3306 — set SYNAIPSE_MARIADB_PORT=3306 if yours is free.
SYNAIPSE_MARIADB_HOST=127.0.0.1
SYNAIPSE_MARIADB_PORT=3307
SYNAIPSE_MARIADB_USER=synaipse
SYNAIPSE_MARIADB_PASSWORD=synaipse
SYNAIPSE_MARIADB_DATABASE=synaipse
# Optional: vault namespace inside a shared DB. Defaults to 1.
# SYNAIPSE_MARIADB_VAULT_ID=1

# Embeddings provider: voyage | ollama | none
# - none   = no semantic search, fulltext only, no Docker needed
# - voyage = hosted API, needs VOYAGE_API_KEY, needs Qdrant (docker)
# - ollama = local LLM via Docker, free, needs Qdrant + Ollama (docker)
EMBEDDINGS_PROVIDER=none

# --- voyage (only if EMBEDDINGS_PROVIDER=voyage) ---
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# --- ollama (only if EMBEDDINGS_PROVIDER=ollama) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# --- qdrant (used unless EMBEDDINGS_PROVIDER=none) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=synaipse

MCP_SERVER_NAME=synaipse
MCP_SERVER_VERSION=0.1.0
# Optional bearer token for the MCP HTTP transport. Unset means the
# /mcp endpoint is unauthenticated — fine for localhost-only dev,
# dangerous if the port is reachable from anywhere else (LAN, Docker,
# reverse proxy). Set this before exposing the port: every request
# must then send `Authorization: Bearer <token>`.
SYNAIPSE_MCP_TOKEN=

# --- Project scope (recommended for shared vaults) ---
# When set, writes are auto-prefixed to Memory/<project>/, get the
# project/<name> tag, and modifications outside that folder are rejected.
# Leave empty to disable; all write tools then return an error.
SYNAIPSE_PROJECT=
# Comma-separated extra tags auto-injected on every Synaipse write
# (in addition to project/<name>). Useful for team/* or kind/* tagging.
SYNAIPSE_PROJECT_TAGS=

# --- Versioning via ngit (no system git required) ---
# Autocommit is ON by default. .ngit/ inside the vault is initialised
# lazily on the first Synaipse-driven write. Set false to disable (the
# history view still reads any existing .ngit/).
# Both lines below are optional — leaving them unset uses the defaults.
SYNAIPSE_GIT_AUTOCOMMIT=true
SYNAIPSE_GIT_AUTHOR=Synaipse <synaipse@local>

WEB_PORT=5757
WEB_API_PORT=3001

# --- Chat / LLM provider ---
# One of: ollama | openai | anthropic | claude-shell
# - ollama       : local LLM via Docker, default URL=http://localhost:11434
# - openai       : OpenAI Chat Completions API (also works for local
#                  OpenAI-compatible servers like llama.cpp, vLLM, LM Studio).
# - anthropic    : claude.ai cloud API (requires SYNAIPSE_CHAT_API_KEY).
# - claude-shell : shells out to the locally-installed Claude Code CLI
#                  (default command: claude), no API key needed if you're
#                  already logged into Claude Code.
SYNAIPSE_CHAT_PROVIDER=ollama
SYNAIPSE_CHAT_MODEL=gemma3:4b
# URL is used by ollama and openai-compatible providers; defaults shown.
# ollama default: http://localhost:11434 — openai default: https://api.openai.com
SYNAIPSE_CHAT_URL=http://localhost:11434
# API key for openai / anthropic providers
SYNAIPSE_CHAT_API_KEY=
# Override the binary name/path for claude-shell (defaults to "claude")
SYNAIPSE_CHAT_COMMAND=

# Ollama tips:
#   gemma3:4b (fast, 4 GB RAM, decent German) — default
#   qwen2.5:7b (best German, 8 GB)
#   gemma3:12b (best reasoning, 12 GB)

# --- Deep Research (web-search agent) ---
# Optional. When configured, the chat panel grows a "🔎 Web" button next to Send.
# Provider: tavily (paid API key) | searxng (self-hosted) | none
SYNAIPSE_RESEARCH_PROVIDER=none
SYNAIPSE_TAVILY_API_KEY=
SYNAIPSE_SEARXNG_URL=

# --- Crawler: GitHub stars ---
# Personal access token, fine-grained or classic — needs 'public_repo' scope
# to read public starred repos, no extra scope needed for the /user endpoint.
GITHUB_TOKEN=
# Optional: defaults to the authenticated user from the token
GITHUB_USERNAME=
# Optional: how many chars of README to keep in each note (default 3000)
GITHUB_CRAWL_README_MAX=3000

# --- Crawler: dev.to latest articles ---
# Get a key at https://dev.to/settings/extensions (DEV community API keys).
DEVTO_API_KEY=
# Optional: how many of the latest articles to fetch (default 100, max 1000)
DEVTO_PER_PAGE=100
# Optional: how many chars of body_markdown to keep per article (default 3000,
# set 0 to skip the per-article detail fetch entirely → metadata-only)
DEVTO_CRAWL_BODY_MAX=3000
# Optional: download all images (cover + inline) into the article folder so
# the vault is fully offline / no traffic back to dev.to (default true).
# Set false to keep image URLs pointing at dev.to / cloudinary.
DEVTO_DOWNLOAD_IMAGES=true