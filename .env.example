SYNAIPSE_VAULT_PATH=./vault
SYNAIPSE_INDEX_CACHE=./data/synaipse-index.json

# Embeddings provider: voyage | ollama | none
# - none   = no semantic search, fulltext only, no Docker needed
# - voyage = hosted API, needs VOYAGE_API_KEY, needs Qdrant (docker)
# - ollama = local LLM via Docker, free, needs Qdrant + Ollama (docker)
EMBEDDINGS_PROVIDER=none

# --- voyage (only if EMBEDDINGS_PROVIDER=voyage) ---
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# --- ollama (only if EMBEDDINGS_PROVIDER=ollama) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# --- qdrant (used unless EMBEDDINGS_PROVIDER=none) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=synaipse

MCP_SERVER_NAME=synaipse
MCP_SERVER_VERSION=0.1.0

# --- Project scope (recommended for shared vaults) ---
# When set, writes are auto-prefixed to Memory/<project>/, get the
# project/<name> tag, and modifications outside that folder are rejected.
# Leave empty to disable; all write tools then return an error.
SYNAIPSE_PROJECT=
# Comma-separated extra tags auto-injected on every Synaipse write
# (in addition to project/<name>). Useful for team/* or kind/* tagging.
SYNAIPSE_PROJECT_TAGS=

# --- Versioning via ngit (no system git required) ---
# Autocommit is ON by default. .ngit/ inside the vault is initialised
# lazily on the first Synaipse-driven write. Set false to disable (the
# history view still reads any existing .ngit/).
# Both lines below are optional — leaving them unset uses the defaults.
SYNAIPSE_GIT_AUTOCOMMIT=true
SYNAIPSE_GIT_AUTHOR=Synaipse <synaipse@local>

WEB_PORT=5757
WEB_API_PORT=3001

# --- Local chat (offline LLM via Ollama) ---
# Reuses the ollama container from EMBEDDINGS_PROVIDER=ollama if you have it.
# Default model gemma3:4b — fast, 4 GB RAM, decent German.
# Alternatives: qwen2.5:7b (best German, 8 GB), gemma3:12b (best reasoning, 12 GB).
SYNAIPSE_CHAT_URL=http://localhost:11434
SYNAIPSE_CHAT_MODEL=gemma3:4b

# --- Crawler: GitHub stars ---
# Personal access token, fine-grained or classic — needs 'public_repo' scope
# to read public starred repos, no extra scope needed for the /user endpoint.
GITHUB_TOKEN=
# Optional: defaults to the authenticated user from the token
GITHUB_USERNAME=
# Optional: how many chars of README to keep in each note (default 3000)
GITHUB_CRAWL_README_MAX=3000

# --- Crawler: dev.to latest articles ---
# Get a key at https://dev.to/settings/extensions (DEV community API keys).
DEVTO_API_KEY=
# Optional: how many of the latest articles to fetch (default 100, max 1000)
DEVTO_PER_PAGE=100
# Optional: how many chars of body_markdown to keep per article (default 3000,
# set 0 to skip the per-article detail fetch entirely → metadata-only)
DEVTO_CRAWL_BODY_MAX=3000
# Optional: download all images (cover + inline) into the article folder so
# the vault is fully offline / no traffic back to dev.to (default true).
# Set false to keep image URLs pointing at dev.to / cloudinary.
DEVTO_DOWNLOAD_IMAGES=true