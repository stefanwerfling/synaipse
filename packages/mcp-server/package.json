{
  "name": "@synaipse/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing Synaipse to Claude Code",
  "type": "module",
  "main": "./dist/Index.js",
  "types": "./dist/Index.d.ts",
  "bin": {
    "synaipse-mcp": "./dist/Index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/Lib.d.ts",
      "import": "./dist/Lib.js"
    },
    "./cli": {
      "types": "./dist/Index.d.ts",
      "import": "./dist/Index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "start": "node --enable-source-maps dist/Index.js",
    "start:http": "SYNAIPSE_MCP_TRANSPORT=http node --enable-source-maps dist/Index.js",
    "dev": "node --enable-source-maps --watch dist/Index.js",
    "user": "node --enable-source-maps dist/UserCli.js"
  },
  "dependencies": {
    "@synaipse/core": "*",
    "@synaipse/server-storage": "*",
    "@synaipse/service": "*",
    "@synaipse/vault": "*",
    "@synaipse/vector": "*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.7"
  }
}