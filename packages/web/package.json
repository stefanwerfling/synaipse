{
  "name": "@synaipse/web",
  "version": "0.1.0",
  "private": true,
  "description": "Synaipse web UI (vanilla TS + DOM)",
  "type": "module",
  "scripts": {
    "build": "tsc --build && vite build",
    "clean": "tsc --build --clean && rimraf dist",
    "dev": "concurrently -k -n api,vite -c blue,magenta \"npm:dev:api\" \"npm:dev:vite\"",
    "dev:api": "node --enable-source-maps --watch dist/server/index.js",
    "dev:vite": "vite",
    "preview": "vite preview",
    "start": "node --enable-source-maps dist/server/index.js"
  },
  "dependencies": {
    "@synaipse/core": "*",
    "@synaipse/mcp-server": "*",
    "@synaipse/service": "*",
    "@synaipse/vault": "*",
    "@synaipse/vector": "*",
    "@types/turndown": "^5.0.6",
    "3d-force-graph": "^1.74.0",
    "cytoscape": "^3.30.4",
    "dotenv": "^16.4.7",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "marked": "^15.0.4",
    "marked-highlight": "^2.2.4",
    "three": "^0.171.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.8",
    "@types/three": "^0.171.0",
    "concurrently": "^9.1.0",
    "rimraf": "^6.0.1",
    "vite": "^6.0.3"
  }
}
